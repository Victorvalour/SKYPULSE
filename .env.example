# Environment Variables

# PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@host:5432/skypulse

# Redis connection string
REDIS_URL=redis://host:6379

# HTTP port (reserved for future HTTP transport — MCP currently uses stdio)
# PORT=3000

# Context Protocol marketplace API key (required when listing on the CTX marketplace)
# CTX_API_KEY=your_context_protocol_api_key

# Node environment (development | production)
NODE_ENV=production

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# Optional: URL of a JSON feed of airline route announcements
# ANNOUNCEMENT_FEED_URL=https://example.com/announcements.json
